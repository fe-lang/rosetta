/// Token + Governance contract.
///
/// Equivalent to the Solidity EIP-2535 Diamond version in sol/.

use std::abi::sol

// ---- Messages ----

msg TokenMsg {
    #[selector = sol("mint(address,uint256)")]
    Mint { to: Address, amount: u256 },
    #[selector = sol("transfer(address,uint256)")]
    Transfer { to: Address, amount: u256 } -> bool,
    #[selector = sol("balanceOf(address)")]
    BalanceOf { account: Address } -> u256,
    #[selector = sol("totalSupply()")]
    TotalSupply -> u256,
}

msg GovMsg {
    #[selector = sol("propose(uint256)")]
    Propose { description: u256 } -> u256,
    #[selector = sol("vote(uint256,bool)")]
    Vote { proposal_id: u256, support: bool },
    #[selector = sol("delegate(address)")]
    Delegate { to: Address },
    #[selector = sol("execute(uint256)")]
    Execute { proposal_id: u256 } -> bool,
    #[selector = sol("getProposal(uint256)")]
    GetProposal { proposal_id: u256 } -> (u256, u256, u256, bool),
    #[selector = sol("proposalCount()")]
    ProposalCount -> u256,
    #[selector = sol("getDelegate(address)")]
    GetDelegate { account: Address } -> Address,
    #[selector = sol("votingPower(address)")]
    VotingPower { account: Address } -> u256,
}

// ---- Storage ----

struct TokenStore {
    total_supply: u256,
    balances: StorageMap<Address, u256>,
}

struct GovStore {
    proposal_count: u256,
    voting_period: u256,
    quorum: u256,
    // Proposal fields as parallel maps (Fe has no storage structs-in-maps yet)
    vote_starts: StorageMap<u256, u256>,
    vote_ends: StorageMap<u256, u256>,
    yes_votes: StorageMap<u256, u256>,
    no_votes: StorageMap<u256, u256>,
    executed: StorageMap<u256, bool>,
    // Double-vote prevention: (proposal_id, voter) -> has_voted
    has_voted: StorageMap<(u256, Address), bool>,
    // Delegation
    delegates: StorageMap<Address, Address>,
    delegated_weight: StorageMap<Address, u256>,
}

struct OwnerStore {
    owner: Address,
}

// ---- Contract ----

pub contract MultiApp uses (ctx: Ctx) {
    mut token_store: TokenStore
    mut gov_store: GovStore
    mut owner_store: OwnerStore

    init(voting_period: u256, quorum: u256) uses (mut owner_store, mut gov_store, ctx) {
        owner_store.owner = ctx.caller()
        gov_store.voting_period = voting_period
        gov_store.quorum = quorum
    }

    recv TokenMsg {
        Mint { to, amount } uses (mut token_store, owner_store, ctx) {
            assert(ctx.caller() == owner_store.owner)
            token_store.total_supply += amount
            token_store.balances.set(key: to, value: token_store.balances.get(key: to) + amount)
        }

        Transfer { to, amount } -> bool uses (mut token_store, ctx) {
            let from = ctx.caller()
            let bal = token_store.balances.get(key: from)
            if bal < amount { return false }
            token_store.balances.set(key: from, value: bal - amount)
            token_store.balances.set(key: to, value: token_store.balances.get(key: to) + amount)
            true
        }

        BalanceOf { account } -> u256 uses (token_store) {
            token_store.balances.get(key: account)
        }

        TotalSupply -> u256 uses (token_store) { token_store.total_supply }
    }

    recv GovMsg {
        Propose { description } -> u256 uses (mut gov_store, token_store, ctx) {
            assert(token_store.balances.get(key: ctx.caller()) > 0)

            let id = gov_store.proposal_count
            gov_store.proposal_count = id + 1

            gov_store.vote_starts.set(key: id, value: ctx.block_number())
            gov_store.vote_ends.set(key: id, value: ctx.block_number() + gov_store.voting_period)

            id
        }

        Vote { proposal_id, support } uses (mut gov_store, token_store, ctx) {
            let caller = ctx.caller()
            let block = ctx.block_number()

            assert(block >= gov_store.vote_starts.get(key: proposal_id))
            assert(block <= gov_store.vote_ends.get(key: proposal_id))
            assert(!gov_store.has_voted.get(key: (proposal_id, caller)))

            gov_store.has_voted.set(key: (proposal_id, caller), value: true)

            let weight = token_store.balances.get(key: caller)
                       + gov_store.delegated_weight.get(key: caller)
            assert(weight > 0)

            if support {
                let v = gov_store.yes_votes.get(key: proposal_id)
                gov_store.yes_votes.set(key: proposal_id, value: v + weight)
            } else {
                let v = gov_store.no_votes.get(key: proposal_id)
                gov_store.no_votes.set(key: proposal_id, value: v + weight)
            }
        }

        Delegate { to } uses (mut gov_store, token_store, ctx) {
            let caller = ctx.caller()
            let weight = token_store.balances.get(key: caller)

            let old_delegate = gov_store.delegates.get(key: caller)
            if old_delegate.inner != 0 {
                let old_w = gov_store.delegated_weight.get(key: old_delegate)
                gov_store.delegated_weight.set(key: old_delegate, value: old_w - weight)
            }

            gov_store.delegates.set(key: caller, value: to)

            if to.inner != 0 {
                let new_w = gov_store.delegated_weight.get(key: to)
                gov_store.delegated_weight.set(key: to, value: new_w + weight)
            }
        }

        Execute { proposal_id } -> bool uses (mut gov_store, ctx) {
            assert(ctx.block_number() > gov_store.vote_ends.get(key: proposal_id))
            assert(!gov_store.executed.get(key: proposal_id))

            let yes = gov_store.yes_votes.get(key: proposal_id)
            let no = gov_store.no_votes.get(key: proposal_id)
            assert(yes + no >= gov_store.quorum)

            gov_store.executed.set(key: proposal_id, value: true)
            yes > no
        }

        GetProposal { proposal_id } -> (u256, u256, u256, bool) uses (gov_store) {
            (
                gov_store.yes_votes.get(key: proposal_id),
                gov_store.no_votes.get(key: proposal_id),
                gov_store.vote_ends.get(key: proposal_id),
                gov_store.executed.get(key: proposal_id),
            )
        }

        ProposalCount -> u256 uses (gov_store) { gov_store.proposal_count }

        GetDelegate { account } -> Address uses (gov_store) {
            gov_store.delegates.get(key: account)
        }

        VotingPower { account } -> u256 uses (token_store, gov_store) {
            token_store.balances.get(key: account)
                + gov_store.delegated_weight.get(key: account)
        }
    }
}
