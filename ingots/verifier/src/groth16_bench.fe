use std::abi::sol
use ec::bn254::{G1Point, G2Point}
use super::groth16::{VerifyingKey, Proof, verify}

/// Verification key for the "factor 33" circuit (from Grant's fe-crypto).
/// Proves knowledge of factors of 33 (3 × 11) without revealing them.
fn test_vk() -> VerifyingKey {
    VerifyingKey {
        alpha1: G1Point {
            x: 18986994054831033570197018374507745079604334824038474376810821382341658341358,
            y: 9857034825708937828129722307559364555144967863984840417006236609097843967147,
        },
        beta2: G2Point {
            x_imag: 9138224228407402916103338031673805059436445969293455575712717090470338056266,
            x_real: 18390029660978007887012397144274200115548124992262045309168725395291020532646,
            y_imag: 13521623794085633987820957758529862860973247929283590310564032250223240671848,
            y_real: 3861004002262797311682051645188776069221901493726904234127961112799581415639,
        },
        gamma2: G2Point {
            x_imag: 11559732032986387107991004021392285783925812861821192530917403151452391805634,
            x_real: 10857046999023057135944570762232829481370756359578518086990519993285655852781,
            y_imag: 4082367875863433681332203403145435568316851327593401208105741076214120093531,
            y_real: 8495653923123431417604973247489272438418190587263600148770280649306958101930,
        },
        delta2: G2Point {
            x_imag: 3810475614507152687978045945018363916901751186873297176897861851851025646174,
            x_real: 11517822973057293310299905404808144348048624735019551898183051528663733638390,
            y_imag: 7205787144229011189765531580637096098035200993493430523391610777645930427053,
            y_real: 18901678484212115678597129685298885730350402277813795965474832351751410499421,
        },
        ic: [
            G1Point {
                x: 67521893739652156791009141370073344821154292280368295170345470354897934196,
                y: 17040597570089860980787757123222393819903832599488360597826421841263128988811,
            },
            G1Point {
                x: 6621938124027639260974226744038109301855429178070752528844179929793898435285,
                y: 2291636765942087387769041560925446553420342985960064087254817725377189124295,
            },
        ],
    }
}

/// Valid proof that 33 = 3 × 11 (from Grant's fe-crypto test vectors).
fn test_proof() -> Proof {
    Proof {
        a: G1Point {
            x: 0x28930e0aeb50e7e3b5f9a54a6abdce99978e00701914dfd4d87f8dc5ea9e1d02,
            y: 0x02c1e99774e679c144aceac4e9fdbc67dc858533d9f49c5933939c89010131b7,
        },
        b: G2Point {
            x_imag: 0x0684d8357689fb95e886a8251db0e142ffdda8032e314750455b9f5ff13159ca,
            x_real: 0x26189ebc171412019704e808c432062721db66c4a22635f20ed422a2147ad5bf,
            y_imag: 0x005d309291fd34bef6248c17779114907b6d912a5a02ddae46d902dbd05e2e1c,
            y_real: 0x01673b4a2e94569e28e23a9ae808b9f92b4d21beca07522f79d16ec419a6e85c,
        },
        c: G1Point {
            x: 0x25170145c09315e2df3c93d155b39df35434469607b0121a16125224190a596a,
            y: 0x05467081343913d54408694735a8d149578e7cbb3168f2b4283a7fe2861a7a42,
        },
    }
}

/// The public input: 33 (= 0x21)
const TEST_INPUT: u256 = 0x21

msg Groth16Msg {
    #[selector = sol("verifyProof(uint256)")]
    VerifyWithTestVectors { input: u256 } -> bool,
}

pub contract Groth16Bench {
    init() {}
    recv Groth16Msg {
        VerifyWithTestVectors { input } -> bool {
            let vk = test_vk()
            let proof = test_proof()
            verify(vk, proof, input)
        }
    }
}
