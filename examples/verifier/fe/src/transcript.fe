use super::field::F_Q
/// SHA256-based Fiat-Shamir transcript.
///
/// Generic write method accepts any type that implements Writable.
/// Raw memory operations use the effects system — callers provide the Evm capability.

use std::evm::crypto
use std::evm::{Evm, RawMem}
use ec::bn254::G1Point


/// A type that can serialize itself into a memory buffer.
pub trait Writable {
    fn byte_size(self) -> u256
    fn write_to(self, ptr: u256) uses (evm: mut Evm)
}

impl Writable for u256 {
    fn byte_size(self) -> u256 { 32 }
    fn write_to(self, ptr: u256) uses (evm: mut Evm) { evm.mstore(addr: ptr, value: self) }
}

impl Writable for G1Point {
    fn byte_size(self) -> u256 { 64 }
    fn write_to(self, ptr: u256) uses (evm: mut Evm) {
        evm.mstore(addr: ptr, value: self.x)
        evm.mstore(addr: ptr + 32, value: self.y)
    }
}

pub struct Transcript {
    pub ptr: u256,
    pub len: u256,
}

impl Copy for Transcript {}

impl Transcript {
    pub fn new() -> Transcript {
        Transcript { ptr: std::evm::alloc(4096), len: 0 }
    }

    pub fn write<T: Writable>(self, val: T) -> Transcript uses (evm: mut Evm) {
        val.write_to(ptr: self.ptr + self.len)
        Transcript { ptr: self.ptr, len: self.len + val.byte_size() }
    }

    pub fn write_label(self, label: u256, label_len: u256) -> Transcript uses (evm: mut Evm) {
        evm.mstore(addr: self.ptr + self.len, value: label)
        Transcript { ptr: self.ptr, len: self.len + label_len }
    }

    // Convenience methods for common types.
    // These delegate to write<T> but provide a familiar API.
    pub fn write_u256(self, val: u256) -> Transcript uses (evm: mut Evm) { self.write(val: val) }
    pub fn write_g1(self, p: G1Point) -> Transcript uses (evm: mut Evm) { self.write(val: p) }

    pub fn squeeze(self) -> (u256, u256, Transcript) {
        let hash = crypto::sha256(self.ptr, self.len)
        (hash % F_Q, hash, Transcript { ptr: self.ptr, len: 0 })
    }
}
