/// Idiomatic Fiat-Shamir transcript using Fe abstractions.
///
/// STATUS: aspirational. Requires:
/// - std::evm::crypto::sha256 (added locally, not upstreamed)
/// - Byte buffer type or [u8; N] runtime support
/// - String::as_bytes() in sonatina backend (missing intrinsic)
///
/// Compare with plonk.fe lines 45-85 (manual mstore/mload buffer management).

use ec::bn254::G1Point
use std::evm::ops

// What we want: a typed transcript that builds SHA256 inputs cleanly.
//
// trait Hasher {
//     fn new() -> Self
//     fn write(mut self, data: u256)
//     fn write_bytes<const N: usize>(mut self, data: [u8; N])
//     fn finish(self) -> u256
// }
//
// struct Sha256Hasher { ptr: u256, len: u256 }
// impl Hasher for Sha256Hasher { ... }
//
// struct Transcript<H: Hasher> {
//     hasher: H,
// }
//
// impl<H: Hasher> Transcript<H> {
//     fn new() -> Self { Transcript { hasher: H::new() } }
//     fn write_u256(mut self, v: u256) -> Self { self.hasher.write(v); self }
//     fn write_g1(mut self, p: G1Point) -> Self {
//         self.hasher.write(p.x)
//         self.hasher.write(p.y)
//         self
//     }
//     fn squeeze(self) -> (u256, Self) {
//         let h = self.hasher.finish()
//         (h % F_Q, Transcript { hasher: H::new() })
//     }
// }
//
// This would replace 40+ lines of manual memory management in plonk.fe.
//
// ISSUES FOUND:
// 1. Fe doesn't have trait bounds on struct fields (Transcript<H: Hasher>)
//    — need to verify this works
// 2. Method chaining (self.write(x).write(y).squeeze()) requires own self
//    returning Self, which should work since Transcript would be Copy
//    if Hasher is Copy
// 3. Generic over hasher means the Merkle module could use the same
//    Transcript with Keccak instead of SHA256
// 4. The gnark BSB22 hash_fr function needs byte-level control:
//    writing individual bytes for the DST string "BSB22-Plonk".
//    A [u8; 11] const would be ideal but String::as_bytes() doesn't
//    work in sonatina yet.

// What we CAN write today (without Fp type, without Hasher trait):

struct Transcript {
    ptr: u256,
    len: u256,
}

impl Copy for Transcript {}

impl Transcript {
    fn new() -> Transcript {
        Transcript { ptr: std::evm::alloc(4096), len: 0 }
    }

    fn reset(self) -> Transcript {
        Transcript { ptr: self.ptr, len: 0 }
    }

    fn write_u256(self, data: u256) -> Transcript {
        ops::mstore(self.ptr + self.len, data)
        Transcript { ptr: self.ptr, len: self.len + 32 }
    }

    fn write_g1(self, p: G1Point) -> Transcript {
        self.write_u256(p.x).write_u256(p.y)
    }

    // TODO: write_bytes<const N: usize>(self, data: [u8; N]) -> Transcript
    // Blocked by lack of byte-level write abstraction.
    // Currently hash_fr uses 11 individual mstore8 calls for "BSB22-Plonk".

    fn squeeze(self) -> (u256, Transcript) {
        let out = std::evm::alloc(32)
        let ok = ops::staticcall(ops::gas(), 2, self.ptr, self.len, out, 32)
        if ok == 0 { ops::revert(0, 0) }
        let h = ops::mload(out)
        (h, self.reset())
    }
}

// With this, the Plonk gamma challenge computation becomes:
//
//   let t = Transcript::new()
//   // Write VK
//   let t = t.write_u256(vk.n).write_u256(vk.n_inv).write_u256(vk.omega)
//   let t = t.write_g1(vk.ql).write_g1(vk.qr).write_g1(vk.qm)
//   // ... etc
//   // Write proof commitments
//   for i in 0..3 { t = t.write_g1(proof.lro[i]) }
//   // Squeeze
//   let (gamma, t) = t.squeeze()
//
// Compare plonk.fe verify() which does this with raw fs_write/fs_squeeze
// and explicit pointer arithmetic.
