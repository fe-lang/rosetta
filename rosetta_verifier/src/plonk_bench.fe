use std::abi::sol
use std::evm::ops
use rosetta_ec::bn254::{G1Point, G2Point}
use super::plonk::{PlonkVK, PlonkProof, verify, debug_challenges}

/// Plonk verification key from gnark PlonkVerifier v4.0.0-rc.3.
/// TODO: validate Fiat-Shamir transcript against real test vectors.
fn example_vk() -> PlonkVK {
    PlonkVK {
        n: 16777216,
        n_inv: 21888241567198334088790460357988866238279339518792980768180410072331574733841,
        omega: 5709868443893258075976348696661355716898495876243883251619397131511003808859,
        nb_public_inputs: 2,
        coset_shift: 5,
        ql: G1Point { x: 17984004271810887111892332882651374483612811613160171882231530673955342124072, y: 13277994607875064672295433418223618455646015691912141325106751561841646085822 },
        qr: G1Point { x: 16336286973672788525637509231329701034039020185740400021577697914995487271901, y: 88284377293612431075210969180485407669835075356048788125030179865751136579 },
        qm: G1Point { x: 10856514239855788242760873537198968126773773371401212930763195728908952457266, y: 9275209459688740642101488227886989724826404626746083670876354123229317070279 },
        qo: G1Point { x: 11483266664351462882096699260743761962335837409017508503826409502538996076321, y: 17394959804451514544078291653193154652690985857122468223674247897665667008225 },
        qk: G1Point { x: 6378083169737830823085597784511445554718388062388953364429190548392020833332, y: 12423874058816725405347015291038805106767729770869142043443023930694783565135 },
        s: [
            G1Point { x: 8432363989348148399267595343996871949745756313266171098803972147558566645391, y: 21830041218908693046173167152196424202345484683169853420596524951634570306585 },
            G1Point { x: 2889872191603241225798623124219684248629415321428218534303823116357979417612, y: 8446598484540146291961338772594737249603462456099116591415979984815127389111 },
            G1Point { x: 12894021857927799668653295424700631150139887020229360316861211114803005826079, y: 5332155988317853016248818837542073627058808403298822656476772250044723938116 },
        ],
        qcp: [
            G1Point { x: 16113316688614670925300831064391815772431716488200414163545127725991745431527, y: 18613967203673816695007264416375047840688367875268537453854528850830700989951 },
        ],
        commit_constraint_idx: [10853426],
        g2_srs: [
            G2Point { x_imag: 11559732032986387107991004021392285783925812861821192530917403151452391805634, x_real: 10857046999023057135944570762232829481370756359578518086990519993285655852781, y_imag: 4082367875863433681332203403145435568316851327593401208105741076214120093531, y_real: 8495653923123431417604973247489272438418190587263600148770280649306958101930 },
            G2Point { x_imag: 15805639136721018565402881920352193254830339253282065586954346329754995870280, x_real: 19089565590083334368588890253123139704298730990782503769911324779715431555531, y_imag: 9779648407879205346559610309258181044130619080926897934572699915909528404984, y_real: 6779728121489434657638426458390319301070371227460768374343986326751507916979 },
        ],
        g1_srs: G1Point { x: 14312776538779914388377568895031746459131577658076416373430523308756343304251, y: 11763105256161367503191792604679297387056316997144156930871823008787082098465 },
    }
}

/// Parse a gnark Plonk proof from calldata.
/// Layout matches gnark's standard proof format.
fn parse_proof(proof_offset: u256) -> PlonkProof {
    PlonkProof {
        lro: [
            G1Point { x: ops::calldataload(proof_offset), y: ops::calldataload(proof_offset + 0x20) },
            G1Point { x: ops::calldataload(proof_offset + 0x40), y: ops::calldataload(proof_offset + 0x60) },
            G1Point { x: ops::calldataload(proof_offset + 0x80), y: ops::calldataload(proof_offset + 0xa0) },
        ],
        z: G1Point {
            x: ops::calldataload(proof_offset + 0x220),
            y: ops::calldataload(proof_offset + 0x240),
        },
        h: [
            G1Point { x: ops::calldataload(proof_offset + 0xc0), y: ops::calldataload(proof_offset + 0xe0) },
            G1Point { x: ops::calldataload(proof_offset + 0x100), y: ops::calldataload(proof_offset + 0x120) },
            G1Point { x: ops::calldataload(proof_offset + 0x140), y: ops::calldataload(proof_offset + 0x160) },
        ],
        bsb22_commitments: [
            G1Point { x: ops::calldataload(proof_offset + 0x320), y: ops::calldataload(proof_offset + 0x340) },
        ],
        batched_h: G1Point {
            x: ops::calldataload(proof_offset + 0x280),
            y: ops::calldataload(proof_offset + 0x2a0),
        },
        claimed_values: [
            ops::calldataload(proof_offset + 0x180),
            ops::calldataload(proof_offset + 0x1a0),
            ops::calldataload(proof_offset + 0x1c0),
            ops::calldataload(proof_offset + 0x1e0),
            ops::calldataload(proof_offset + 0x200),
            ops::calldataload(proof_offset + 0x300),
        ],
        z_shifted_h: G1Point {
            x: ops::calldataload(proof_offset + 0x2c0),
            y: ops::calldataload(proof_offset + 0x2e0),
        },
        z_shifted_value: ops::calldataload(proof_offset + 0x260),
    }
}

msg PlonkMsg {
    #[selector = sol("verifyPlonkProof(uint256,uint256,uint256)")]
    VerifyPlonkProof { pi0: u256, pi1: u256, proof_calldata_offset: u256 } -> bool,
    #[selector = sol("debugGamma(uint256,uint256,uint256)")]
    DebugGamma { pi0: u256, pi1: u256, proof_calldata_offset: u256 } -> u256,
    #[selector = sol("debugBeta(uint256,uint256,uint256)")]
    DebugBeta { pi0: u256, pi1: u256, proof_calldata_offset: u256 } -> u256,
    #[selector = sol("debugAlpha(uint256,uint256,uint256)")]
    DebugAlpha { pi0: u256, pi1: u256, proof_calldata_offset: u256 } -> u256,
    #[selector = sol("debugZeta(uint256,uint256,uint256)")]
    DebugZeta { pi0: u256, pi1: u256, proof_calldata_offset: u256 } -> u256,
    #[selector = sol("debugPI(uint256,uint256,uint256)")]
    DebugPI { pi0: u256, pi1: u256, proof_calldata_offset: u256 } -> (u256, u256),
    // Removed debug endpoints to simplify — use Fe tests for debugging
    #[selector = sol("debugProofL(uint256)")]
    DebugProofL { proof_calldata_offset: u256 } -> u256,
    #[selector = sol("debugProofZ(uint256)")]
    DebugProofZ { proof_calldata_offset: u256 } -> (u256, u256),
}

pub contract PlonkBench {
    init() {}
    recv PlonkMsg {
        VerifyPlonkProof { pi0, pi1, proof_calldata_offset } -> bool {
            let vk = example_vk()
            let pub_inputs: [u256; 2] = [pi0, pi1]
            let proof = parse_proof(proof_calldata_offset)
            verify(vk, proof, pub_inputs)
        }
        DebugGamma { pi0, pi1, proof_calldata_offset } -> u256 {
            let vk = example_vk()
            let pub_inputs: [u256; 2] = [pi0, pi1]
            let proof = parse_proof(proof_calldata_offset)
            debug_challenges(vk, proof, pub_inputs).0
        }
        DebugBeta { pi0, pi1, proof_calldata_offset } -> u256 {
            let vk = example_vk()
            let pub_inputs: [u256; 2] = [pi0, pi1]
            let proof = parse_proof(proof_calldata_offset)
            debug_challenges(vk, proof, pub_inputs).1
        }
        DebugAlpha { pi0, pi1, proof_calldata_offset } -> u256 {
            let vk = example_vk()
            let pub_inputs: [u256; 2] = [pi0, pi1]
            let proof = parse_proof(proof_calldata_offset)
            debug_challenges(vk, proof, pub_inputs).2
        }
        DebugZeta { pi0, pi1, proof_calldata_offset } -> u256 {
            let vk = example_vk()
            let pub_inputs: [u256; 2] = [pi0, pi1]
            let proof = parse_proof(proof_calldata_offset)
            debug_challenges(vk, proof, pub_inputs).3
        }
        DebugPI { pi0, pi1, proof_calldata_offset } -> (u256, u256) {
            let vk = example_vk()
            let pub_inputs: [u256; 2] = [pi0, pi1]
            let proof = parse_proof(proof_calldata_offset)
            super::plonk::debug_pi(vk, proof, pub_inputs)
        }
        DebugProofL { proof_calldata_offset } -> u256 {
            let proof = parse_proof(proof_calldata_offset)
            proof.claimed_values[0]
        }
        DebugProofZ { proof_calldata_offset } -> (u256, u256) {
            let proof = parse_proof(proof_calldata_offset)
            (proof.z.x, proof.z.y)
        }
    }
}
