/// Idiomatic Poseidon hash.
///
/// In Solidity, Poseidon can't be written at all — it's generated as
/// raw EVM bytecode by JavaScript. In Fe, it's readable code with
/// type-safe field arithmetic.
///
/// STATUS: blocked by sonatina#227 (stack object overflow on Fp
/// wrapper functions at this scale). Works at small scale.
///
/// VISION: with const fn, the round constants themselves could be
/// computed at compile time from the field parameters, eliminating
/// the 400-line constants.fe file entirely.

use std::evm::ops::{addmod, mulmod}
use core::ops::{Add, Mul}

/// BN254 scalar field element.
/// Two Fp values can be added and multiplied — the modular reduction
/// is handled by the type, not by the caller. Compare Solidity where
/// every operation must manually pass the modulus.
pub struct Fp {
    pub val: u256,
}

const P: u256 = 0x30644e72e131a029b85045b68181585d2833e84879b9709143e1f593f0000001

impl Copy for Fp {}

impl Add for Fp {
    fn add(own self, _ rhs: own Fp) -> Fp {
        Fp { val: addmod(self.val, rhs.val, P) }
    }
}

impl Mul for Fp {
    fn mul(own self, _ rhs: own Fp) -> Fp {
        Fp { val: mulmod(self.val, rhs.val, P) }
    }
}

impl Fp {
    pub fn new(val: u256) -> Fp { Fp { val } }
    pub fn zero() -> Fp { Fp { val: 0 } }

    /// S-box: x^5. The core nonlinear operation in Poseidon.
    pub fn pow5(self) -> Fp {
        let x2 = self * self
        let x4 = x2 * x2
        x4 * self
    }
}

